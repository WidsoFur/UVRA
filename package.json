{
  "name": "uvra-gloves",
  "version": "1.0.0",
  "private": true,
  "description": "UVRA - Universal VR Application for DIY VR Gloves",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:react\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "electron .",
    "build": "vite build && electron-builder",
    "build:react": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lucide-react": "^0.475.0",
    "framer-motion": "^12.6.3"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^6.2.6",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1"
  },
  "build": {
    "appId": "com.uvra.gloves",
    "productName": "UVRA Gloves",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
