#pragma once

// ===== PART 1: BOARD SELECTION =====
// Uncomment exactly ONE board:

//#define BOARD_ESP32          // JSON protocol (~400 bytes/packet)
//#define BOARD_ESP32_S3       // JSON protocol (~400 bytes/packet)
#define BOARD_ESP32_C3_MUX    // UVRA Binary v1 protocol (46 bytes/packet)

// ===== PROTOCOL DETAILS =====
// ESP32/ESP32-S3: JSON over UDP (legacy, verbose, ~400 bytes)
// ESP32-C3: UVRA Binary v1 (compact, 46 bytes):
//   [0] 0x55 magic
//   [1] hand (0=left,1=right)  
//   [2..18] MAC address (17 bytes)
//   [19..28] raw ADC flex (5×uint16, 0-4095)
//   [29..38] normalized flex (5×uint16, 0-10000)
//   [39..42] joystick X,Y (2×int16, -10000..10000)
//   [43] button bitmask
//   [44..45] trigger (uint16, 0-10000)

// ===== НАСТРОЙКИ WiFi =====
#define WIFI_SSID     "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// ===== НАСТРОЙКИ UVRA =====
// ТУТ НИЧЕГО НЕ ТРОГАЙ, ЕСЛИ НЕ ЗНАЕШЬ ЧТО ДЕЛАЕШЬ

// Порт для отправки данных (должен совпадать с портом в приложении UVRA)
#define UVRA_DATA_PORT     7777
// Порт для автообнаружения (discovery)
#define UVRA_DISCOVERY_PORT 7776
// Интервал отправки discovery-запросов (мс)
#define DISCOVERY_INTERVAL  2000

// ===== РУКА =====
// Рука: "left" или "right" на каждый контроллер отдельно. Можно поставить unknown тогда надо будет указать в приложении

#define HAND               "right"

// ===== ПОДКЛЮЧЁННЫЕ КОМПОНЕНТЫ =====
// Отключи то, что не подключено физически (false = не читать, отправлять нули)
#define HAS_FINGERS        true
#define HAS_JOYSTICK       false
#define HAS_BUTTONS        false
#define HAS_TRIGGER        false

// ===== ИНВЕРСИЯ СТИКА =====
#define INVERT_JOY_X       true
#define INVERT_JOY_Y       false

// ===== ПИНЫ ДАТЧИКОВ =====
// Если нужны кастомные пины — задайте их здесь, они перезапишут дефолты ниже.
// Например:
// #define FLEX_THUMB_PIN  4

// --- Дефолтные пины для каждой платы ---
#if defined(BOARD_ESP32) //<---------------------  Тебе нужны вот эти
  // ESP32 classic: ADC1 каналы на GPIO 32-39
  #ifndef FLEX_THUMB_PIN
    #define FLEX_THUMB_PIN   34  //<---------------------  Большой палец
  #endif
  #ifndef FLEX_INDEX_PIN
    #define FLEX_INDEX_PIN   26  //<---------------------  Указательный палец
  #endif
  #ifndef FLEX_MIDDLE_PIN
    #define FLEX_MIDDLE_PIN  27  //<---------------------  Средний палец
  #endif
  #ifndef FLEX_RING_PIN
    #define FLEX_RING_PIN    14  //<---------------------  Безымянный палец
  #endif
  #ifndef FLEX_PINKY_PIN
    #define FLEX_PINKY_PIN   12  //<---------------------  Мизинец
  #endif

  #ifndef JOY_X_PIN
    #define JOY_X_PIN        32  //<---------------------  Стик X
  #endif
  #ifndef JOY_Y_PIN
    #define JOY_Y_PIN        33  //<---------------------  Стик Y
  #endif
  #ifndef JOY_BTN_PIN
    #define JOY_BTN_PIN      25  //<---------------------  Стик кнопка
  #endif

  #ifndef BTN_A_PIN
    #define BTN_A_PIN        20  //<---------------------  Кнопка A
  #endif
  #ifndef BTN_B_PIN
    #define BTN_B_PIN        18  //<---------------------  Кнопка B
  #endif
  #ifndef TRIGGER_PIN
    #define TRIGGER_PIN      19  //<---------------------  Курок
  #endif

#elif defined(BOARD_ESP32_S3)
  // ESP32-S3: ADC1 каналы на GPIO 1-10, ADC2 на GPIO 11-20
  #ifndef FLEX_THUMB_PIN
    #define FLEX_THUMB_PIN   1
  #endif
  #ifndef FLEX_INDEX_PIN
    #define FLEX_INDEX_PIN   2
  #endif
  #ifndef FLEX_MIDDLE_PIN
    #define FLEX_MIDDLE_PIN  3
  #endif
  #ifndef FLEX_RING_PIN
    #define FLEX_RING_PIN    4
  #endif
  #ifndef FLEX_PINKY_PIN
    #define FLEX_PINKY_PIN   5
  #endif

  #ifndef JOY_X_PIN
    #define JOY_X_PIN        6
  #endif
  #ifndef JOY_Y_PIN
    #define JOY_Y_PIN        7
  #endif
  #ifndef JOY_BTN_PIN
    #define JOY_BTN_PIN      15
  #endif

  #ifndef BTN_A_PIN
    #define BTN_A_PIN        16
  #endif
  #ifndef BTN_B_PIN
    #define BTN_B_PIN        17
  #endif
  #ifndef TRIGGER_PIN
    #define TRIGGER_PIN      8
  #endif

#elif defined(BOARD_ESP32_C3_MUX)
  // ESP32-C3 Super Mini + CD74HC4067 мультиплексор
  // Все аналоговые/цифровые входы через мультиплексор

  // Пин сигнала мультиплексора (SIG)
  #ifndef MUX_SIG_PIN
    #define MUX_SIG_PIN      3
  #endif
  // Пины выбора канала (S0-S3)
  #ifndef MUX_S0_PIN
    #define MUX_S0_PIN       6
  #endif
  #ifndef MUX_S1_PIN
    #define MUX_S1_PIN       7
  #endif
  #ifndef MUX_S2_PIN
    #define MUX_S2_PIN       4
  #endif
  #ifndef MUX_S3_PIN
    #define MUX_S3_PIN       10
  #endif

  // Каналы мультиплексора
  #define MUX_CH_PINKY     0
  #define MUX_CH_RING      1
  #define MUX_CH_MIDDLE    2
  #define MUX_CH_INDEX     3
  #define MUX_CH_THUMB     4
  #define MUX_CH_JOY_X     5
  #define MUX_CH_JOY_Y     6
  #define MUX_CH_JOY_BTN   7
  #define MUX_CH_BTN_A     8
  #define MUX_CH_BTN_B     9
  #define MUX_CH_TRIGGER   10

  // Порядок каналов пальцев: thumb, index, middle, ring, pinky
  #define MUX_FLEX_CHANNELS { MUX_CH_THUMB, MUX_CH_INDEX, MUX_CH_MIDDLE, MUX_CH_RING, MUX_CH_PINKY }

  // Пороги для цифровых входов через мультиплексор (кнопки подтянуты к VCC)
  #define MUX_DIGITAL_THRESHOLD 2048

  // Заглушки для совместимости (не используются в MUX режиме)
  #define FLEX_THUMB_PIN   0
  #define FLEX_INDEX_PIN   0
  #define FLEX_MIDDLE_PIN  0
  #define FLEX_RING_PIN    0
  #define FLEX_PINKY_PIN   0
  #define JOY_X_PIN        0
  #define JOY_Y_PIN        0
  #define JOY_BTN_PIN      0
  #define BTN_A_PIN        0
  #define BTN_B_PIN        0
  #define TRIGGER_PIN      0

#else
  #error "Выберите плату: раскомментируйте BOARD_ESP32, BOARD_ESP32_S3 или BOARD_ESP32_C3_MUX в config.h"
#endif

// ===== КАЛИБРОВКА =====
// Минимальные значения АЦП для каждого пальца (палец разогнут)
#define FLEX_THUMB_MIN   0
#define FLEX_INDEX_MIN   0
#define FLEX_MIDDLE_MIN  0
#define FLEX_RING_MIN    0
#define FLEX_PINKY_MIN   0

// Максимальные значения АЦП для каждого пальца (палец согнут)
#define FLEX_THUMB_MAX   4095
#define FLEX_INDEX_MAX   4095
#define FLEX_MIDDLE_MAX  4095
#define FLEX_RING_MAX    4095
#define FLEX_PINKY_MAX   4095

// ===== ЧАСТОТА ОТПРАВКИ =====
// Задержка между отправками данных (мс). 10 = ~100 Гц
#define SEND_INTERVAL_MS 10
